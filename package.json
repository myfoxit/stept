{
  "name": "ondoki-desktop-electron",
  "productName": "Ondoki Desktop",
  "version": "1.0.0",
  "description": "Cross-platform screen recording and AI guide generation tool",
  "main": "lib/main/index.js",
  "homepage": "https://github.com/myfoxit/ondoki-desktop-electron",
  "repository": {
    "type": "git",
    "url": "https://github.com/myfoxit/ondoki-desktop-electron.git"
  },
  "author": {
    "name": "MyFoxIT",
    "email": "contact@myfoxit.com"
  },
  "license": "MIT",
  "scripts": {
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "webpack --mode production",
    "dev": "npm run build:main && npm run dev:renderer",
    "dev:renderer": "webpack serve --mode development",
    "start": "npm run build && electron . --no-sandbox",
    "dev:electron": "npm run build && electron . --development --no-sandbox",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "clean": "rimraf lib dist out .webpack",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "electron",
    "screen-recording",
    "ai",
    "automation",
    "guide-generation",
    "cross-platform"
  ],
  "devDependencies": {
    "@electron-forge/cli": "^7.4.0",
    "@electron-forge/maker-deb": "^7.4.0",
    "@electron-forge/maker-dmg": "^7.4.0",
    "@electron-forge/maker-rpm": "^7.4.0",
    "@electron-forge/maker-squirrel": "^7.4.0",
    "@electron-forge/maker-zip": "^7.4.0",
    "@types/node": "^20.12.7",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^7.7.1",
    "@typescript-eslint/parser": "^7.7.1",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.19",
    "css-loader": "^7.1.1",
    "electron": "^30.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "html-webpack-plugin": "^5.6.0",
    "postcss": "^8.4.38",
    "postcss-loader": "^8.1.1",
    "rimraf": "^5.0.5",
    "style-loader": "^4.0.0",
    "tailwindcss": "^3.4.3",
    "ts-loader": "^9.5.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "lucide-react": "^0.564.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "screenshot-desktop": "^1.12.7",
    "sharp": "^0.33.3",
    "ws": "^8.17.0"
  },
  "build": {
    "appId": "com.myfoxit.ondoki-desktop",
    "productName": "Ondoki Desktop",
    "directories": {
      "output": "dist"
    },
    "files": [
      "lib/",
      "assets/",
      "node_modules/",
      "package.json"
    ],
    "icon": "assets/icon.png",
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": "nsis"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "protocols": [
      {
        "name": "ondoki-protocol",
        "schemes": [
          "ondoki"
        ]
      }
    ]
  },
  "config": {
    "forge": "./forge.config.js"
  }
}
