# Storage backend: local | s3 | gcs | azure
STORAGE_BACKEND=local

# Local storage
LOCAL_STORAGE_PATH=/app/storage/recordings
UPLOAD_DIR=./uploads

# S3-compatible storage (AWS S3, Cloudflare R2, MinIO)
# S3_BUCKET=ondoki-uploads
# S3_REGION=eu-central-1
# S3_ENDPOINT_URL=            # For R2/MinIO: https://your-account.r2.cloudflarestorage.com
# S3_PREFIX=uploads
# AWS_ACCESS_KEY_ID=           # Or use IAM roles
# AWS_SECRET_ACCESS_KEY=
# S3_ACCESS_KEY_ID=            # Alternative: explicit creds for MinIO/R2
# S3_SECRET_ACCESS_KEY=

# GCS storage
# STORAGE_GCS_BUCKET=
# STORAGE_GCS_CREDENTIALS_FILE=

# Azure Blob storage
# STORAGE_AZURE_CONTAINER=
# STORAGE_AZURE_CONNECTION_STRING=
