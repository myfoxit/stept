      },
      "has_url": true,
      "description_contains": ["edit"]
    },
    {
      "action_type": "Left Click",
      "element": {
        "tagName": "button",
        "testId": "page-2",
        "has_selector": true
      },
      "has_url": true,
      "description_contains": ["2"]
