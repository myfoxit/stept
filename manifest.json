{
  "manifest_version": 3,
  "name": "Ondoki Process Recorder",
  "version": "1.0.1",
  "description": "Record browser process steps with screenshots — powered by Ondoki",
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "identity",
    "scripting",
    "sidePanel",
    "webNavigation"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "https://app.ondoki.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
