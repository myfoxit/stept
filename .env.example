# ══════════════════════════════════════════════════════════════
# Ondoki — Environment Configuration
# Copy to .env and fill in your values
# ══════════════════════════════════════════════════════════════

# ── Environment ───────────────────────────────────────────────
# Options: local | staging | production | test
ENVIRONMENT=local

# ── Domain (used by Caddy for automatic HTTPS in production) ─
# Set to your domain (e.g. app.ondoki.com) in production
DOMAIN=localhost

# ── Database ──────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ondoki
# Full async connection string (used by backend directly)
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# ── Auth / Security ──────────────────────────────────────────
# JWT signing key — MUST be a strong random string in production
# Generate: openssl rand -hex 32
JWT_SECRET=change-me-in-production

# Fernet key for encrypting API keys at rest
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ONDOKI_ENCRYPTION_KEY=

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
# Password for Redis in production (set in redis.conf or via command)
# REDIS_PASSWORD=

# ── Celery (media worker) ────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# In production, set to your actual domain(s)
CORS_ORIGINS=http://localhost:5173,ondoki://
# Regex pattern for CORS origin matching (production)
# CORS_ORIGIN_REGEX=^https://.*\.ondoki\.com$
# Allowed origins for CSRF checks (comma-separated, in addition to FRONTEND_URL)
# ALLOWED_ORIGINS=https://app.ondoki.com

# ── Frontend URL ──────────────────────────────────────────────
# Used for CORS, email links, and OAuth callbacks
FRONTEND_URL=http://localhost:5173

# ── Gotenberg (PDF export) ────────────────────────────────────
GOTENBERG_URL=http://gotenberg:3000

# ── SMTP (email verification & password reset) ───────────────
# Leave SR_SMTP_HOST empty to disable email sending
SR_SMTP_HOST=
SR_SMTP_PORT=587
SR_SMTP_USER=
SR_SMTP_PASS=
SR_FROM_EMAIL=noreply@ondoki.com

# ── Storage ───────────────────────────────────────────────────
# Storage backend: local | s3 | gcs | azure
STORAGE_BACKEND=local

# Local storage
LOCAL_STORAGE_PATH=./storage/recordings
UPLOAD_DIR=./uploads

# S3-compatible storage (AWS S3, Cloudflare R2, MinIO)
# S3_BUCKET=ondoki-uploads
# S3_REGION=eu-central-1
# S3_ENDPOINT_URL=            # For R2/MinIO: https://your-account.r2.cloudflarestorage.com
# S3_PREFIX=uploads
# AWS_ACCESS_KEY_ID=           # Or use IAM roles
# AWS_SECRET_ACCESS_KEY=
# S3_ACCESS_KEY_ID=            # Alternative: explicit creds for MinIO/R2
# S3_SECRET_ACCESS_KEY=

# GCS storage
# STORAGE_GCS_BUCKET=
# STORAGE_GCS_CREDENTIALS_FILE=

# Azure Blob storage
# STORAGE_AZURE_CONTAINER=
# STORAGE_AZURE_CONNECTION_STRING=

# ── LLM / AI (optional — can also be configured from the UI) ─
# Supported providers: openai | anthropic | ollama | copilot | custom
# ONDOKI_LLM_PROVIDER=openai
# ONDOKI_LLM_API_KEY=sk-...
# ONDOKI_LLM_MODEL=gpt-4o
# ONDOKI_LLM_BASE_URL=https://api.openai.com

# ── SendCloak / PII Protection (optional) ────────────────────
# Enable to obfuscate PII before sending to AI providers
SENDCLOAK_ENABLED=false
SENDCLOAK_URL=http://sendcloak:9090
# SENDCLOAK_STRATEGY=semantic

# ── DataVeil Privacy Proxy (optional) ─────────────────────────
# DATAVEIL_ENABLED=false
# DATAVEIL_URL=http://localhost:8080

# ── Presidio (used by SendCloak) ──────────────────────────────
# Language pack: en (English-only) | eu (English + German + French + Spanish + Italian)
PRESIDIO_LANG_PACK=en
PRESIDIO_LANGUAGE=en

# ── Video/Media Processing ────────────────────────────────────
# OPENAI_API_KEY=  # For Whisper transcription
WHISPER_MODEL=base
