# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ondoki
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ondoki

# ── Auth ──────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
# For JWT key rotation: comma-separated list (sign with first, verify all)
# JWT_SECRET=new-secret,old-secret

# ── Security ─────────────────────────────────────────────
# Fernet key for encrypting API keys at rest.
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If not set, a random key is generated (not persistent across restarts!)
# ONDOKI_ENCRYPTION_KEY=

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Gotenberg (PDF export) ────────────────────────────────
GOTENBERG_URL=http://localhost:3000

# ── Frontend URL (CORS / email links) ────────────────────
FRONTEND_URL=http://localhost:5173

# ── SMTP (email verification) ────────────────────────────
sr_smtp_host=127.0.0.1
sr_smtp_port=1025

# ── Storage ───────────────────────────────────────────────
storage_type=local
local_storage_path=./storage/recordings

# ── DataVeil (optional PII protection) ───────────────────
# DATAVEIL_ENABLED=false
# DATAVEIL_URL=http://localhost:8080

# ── LLM (optional — can also be configured from the UI) ──
# Supported providers: openai, anthropic, ollama, copilot, custom
# ONDOKI_LLM_PROVIDER=openai
# ONDOKI_LLM_API_KEY=sk-...
# ONDOKI_LLM_MODEL=gpt-4o
# ONDOKI_LLM_BASE_URL=https://api.openai.com
