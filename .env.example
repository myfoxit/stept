# ══════════════════════════════════════════════════════════════
# Stept — Environment Configuration
# Copy to .env and fill in your values
# ══════════════════════════════════════════════════════════════

# ── Environment ───────────────────────────────────────────────
# Options: local | staging | production | test
ENVIRONMENT=local

# ── Domain (used by Caddy for automatic HTTPS in production) ─
# Set to your domain (e.g. app.stept.com) in production
DOMAIN=localhost

# ── Database ──────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=stept
# Full async connection string (used by backend directly)
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# ── Auth / Security ──────────────────────────────────────────
# JWT signing key — MUST be a strong random string in production
# Generate: openssl rand -hex 32
JWT_SECRET=change-me-in-production

# Fernet key for encrypting API keys at rest
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
STEPT_ENCRYPTION_KEY=

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
# Password for Redis in production (set in redis.conf or via command)
# REDIS_PASSWORD=

# ── Celery (media worker) ────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# In production, set to your actual domain(s)
CORS_ORIGINS=http://localhost:5173,stept://
# Regex pattern for CORS origin matching (production)
# CORS_ORIGIN_REGEX=^https://.*\.stept\.com$
# Allowed origins for CSRF checks (comma-separated, in addition to FRONTEND_URL)
# ALLOWED_ORIGINS=https://app.stept.com

# ── Frontend URL ──────────────────────────────────────────────
# Used for CORS, email links, and OAuth callbacks
FRONTEND_URL=http://localhost:5173

# ── Gotenberg (PDF export) ────────────────────────────────────
GOTENBERG_URL=http://gotenberg:3000

# ── SMTP (email verification & password reset) ───────────────
# SMTP server hostname (e.g. smtp.resend.com, smtp.gmail.com)
SMTP_HOST=
# SMTP port: 587 for STARTTLS, 465 for implicit SSL, 25 for plain
SMTP_PORT=587
# SMTP login credentials
SMTP_USER=
SMTP_PASS=
# Sender email address shown in From: header
SMTP_FROM=noreply@stept.com
# TLS/SSL auto-detected from port; override if needed
# SMTP_USE_TLS=true     # STARTTLS (port 587)
# SMTP_USE_SSL=false    # Implicit SSL (port 465)

# ── OAuth — Google (social login) ────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {FRONTEND_URL}/api/v1/auth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── OAuth — GitHub (social login) ────────────────────────────
# Create an OAuth app at https://github.com/settings/developers
# Authorization callback URL: {FRONTEND_URL}/api/v1/auth/github/callback
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ── Storage ───────────────────────────────────────────────────
# Storage backend: local | s3 | gcs | azure
STORAGE_BACKEND=local

# Local storage
LOCAL_STORAGE_PATH=./storage/recordings
UPLOAD_DIR=./uploads

# S3-compatible storage (AWS S3, Cloudflare R2, MinIO, DigitalOcean Spaces, Backblaze B2, Wasabi, Hetzner)
# S3_BUCKET=stept-uploads
# S3_REGION=eu-central-1
# S3_ENDPOINT_URL=               # Leave empty for AWS S3; set for R2/MinIO/Spaces/etc.
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PREFIX=uploads
# S3_FORCE_PATH_STYLE=false      # Set to true for MinIO, LocalStack

# Google Cloud Storage
# STORAGE_GCS_BUCKET=
# STORAGE_GCS_CREDENTIALS_FILE=  # Path to service account JSON; omit for ADC on GCP

# Azure Blob Storage
# STORAGE_AZURE_CONTAINER=
# STORAGE_AZURE_CONNECTION_STRING=

# ── LLM / AI (optional — can also be configured from the UI) ─
# Supported providers: openai | anthropic | ollama | copilot | custom
# STEPT_LLM_PROVIDER=openai
# STEPT_LLM_API_KEY=sk-...
# STEPT_LLM_MODEL=gpt-4o
# STEPT_LLM_BASE_URL=https://api.openai.com

# ── SendCloak — PII Protection (optional) ─────────────────────
# Obfuscates PII before sending to AI providers, deobfuscates responses.
# Enable the service: docker compose --profile privacy up -d
# Add Presidio for enhanced detection: docker compose --profile privacy --profile presidio up -d
SENDCLOAK_ENABLED=false
SENDCLOAK_URL=http://sendcloak:9090
# SENDCLOAK_STRATEGY=semantic      # Options: semantic, regex
# PRESIDIO_LANGUAGE=en              # Default language for Presidio (if enabled)

# ── Video/Media Processing ────────────────────────────────────
# OPENAI_API_KEY=  # For Whisper transcription
WHISPER_MODEL=base
